# ── LLM ──────────────────────────────────────────────
# LLM_PROVIDER: ollama | openrouter | openai
#   ollama     = tamamen yerel, ücretsiz, rate-limit yok (Ollama çalışmalı)
#   openrouter = OpenAI uyumlu; ücretsiz ":free" modeller sık rate-limit verir
#   openai     = gpt-4o-mini (ucuz, güvenilir, anahtar gerekir)
LLM_PROVIDER=ollama
# ollama:     yerel model adı (örn. qwen2.5:7b, llama3.1:8b)
# openrouter: "openai/gpt-4o-mini" veya bir ":free" model
# openai:     "gpt-4o-mini"
LLM_MODEL=qwen2.5:7b
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://localhost:11434

# ── Embeddings ───────────────────────────────────────
# EMBEDDING_PROVIDER: local | openai
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Data sources ─────────────────────────────────────
# Optional; leave empty to use CoinGecko's public endpoint.
COINGECKO_API_KEY=
# Optional CryptoPanic API token.
CRYPTOPANIC_API_KEY=

# ── Storage ──────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── Cache (optional; disabled when empty) ────────────
REDIS_URL=

# ── News ─────────────────────────────────────────────
NEWS_LOOKBACK_HOURS=48
MAX_NEWS_ITEMS=40
